platform :ios, '13.0'

use_frameworks!

# Change the target name to your app target name in Xcode.
target 'WildEdgeExamplesApp' do
  # Google ML Kit (Face Detection + Vision)
  pod 'GoogleMLKit/FaceDetection'
  pod 'GoogleMLKit/Vision'

  # ONNX Runtime Objective-C API
  pod 'onnxruntime-objc'

  # TensorFlow Lite Swift API
  pod 'TensorFlowLiteSwift'

  # Optional: Metal delegate for GPU acceleration
  # pod 'TensorFlowLiteSwift/Metal'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
